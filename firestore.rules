rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 256;
    }

    function isValidCachedImage(data) {
      return data.keys().hasAll(['botId', 'url']) &&
             data.botId is string &&
             data.url is string;
    }

    match /cached_images/{botId} {
      allow get: if true; // Publicly readable
      allow list: if false; // No bulk listing needed for client
      allow create, update: if isValidId(botId) && isValidCachedImage(request.resource.data);
      allow delete: if false;
    }
  }
}
